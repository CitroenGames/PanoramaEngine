[project:QuickJS]
type = lib
c_standard = 11
sources = {
    dtoa.c
    libregexp.c
    libunicode.c
    quickjs.c
    quickjs-libc.c
}
headers = *.h
includes = .
public_includes = .
defines = QUICKJS_NG_BUILD, QJS_BUILD_LIBC, _GNU_SOURCE
compile_as = CompileAsC
warning_level = Level3
disable_warnings = 4018, 4061, 4098, 4100, 4146, 4200, 4242, 4244, 4245, 4267, 4334, 4388, 4389, 4710, 4711, 4820, 4996, 5045
utf8 = true
multiprocessor = true

if(Windows)
{
    defines = WIN32_LEAN_AND_MEAN, _WIN32_WINNT=0x0601
    cflags = /experimental:c11atomics /J
}
if(posix)
{
    cflags = -funsigned-char
}
if(Linux)
{
    public_libs = m, pthread, dl
}
if(macOS)
{
    public_libs = pthread
}

[config:Debug|x64]
runtime_library = MultiThreadedDebug
optimization = Disabled
debug_info = ProgramDatabase
generate_debug_info = true
outdir = ../../bin/x64/Debug
intdir = ../../build/obj/x64/Debug/QuickJS

[config:Debug|macOS]
runtime_library = MultiThreadedDebug
optimization = Disabled
debug_info = ProgramDatabase
generate_debug_info = true
outdir = ../../bin/posix/Debug
intdir = ../../build/obj/posix/Debug/QuickJS

[config:Debug|Linux]
runtime_library = MultiThreadedDebug
optimization = Disabled
debug_info = ProgramDatabase
generate_debug_info = true
outdir = ../../bin/posix/Debug
intdir = ../../build/obj/posix/Debug/QuickJS

[config:Release|x64]
runtime_library = MultiThreaded
optimization = MaxSpeed
debug_info = ProgramDatabase
generate_debug_info = true
outdir = ../../bin/x64/Release
intdir = ../../build/obj/x64/Release/QuickJS

[config:Release|macOS]
runtime_library = MultiThreaded
optimization = MaxSpeed
debug_info = ProgramDatabase
generate_debug_info = true
outdir = ../../bin/posix/Release
intdir = ../../build/obj/posix/Release/QuickJS

[config:Release|Linux]
runtime_library = MultiThreaded
optimization = MaxSpeed
debug_info = ProgramDatabase
generate_debug_info = true
outdir = ../../bin/posix/Release
intdir = ../../build/obj/posix/Release/QuickJS
